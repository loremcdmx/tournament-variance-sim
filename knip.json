{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/app/**/{page,layout,loading,error,not-found,route,template,default}.{ts,tsx}",
    "scripts/**/*.{ts,mjs,js}"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "scripts/**/*.{ts,mjs,js}"
  ],
  "ignoreDependencies": [
    "postcss",
    "tailwindcss"
  ],
  "ignoreExportsUsedInFile": true
}
